    if (city) _refreshCityForm(city);
};

S._deleteCity = function(id) {
    S.cities = S.cities.filter(c => c.id !== id);
    if (S.selectedCityId === id) {
        S.selectedCityId = null;
        const form = document.getElementById("se-cnp-city-form-card");
